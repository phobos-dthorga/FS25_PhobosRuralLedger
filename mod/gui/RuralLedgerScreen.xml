                    <Text profile="rlInfoListLabel" name="label"/>
                    <Text profile="rlInfoListValue" name="value"/>
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="rlOverviewSliderBox">
                <Slider profile="fs25_listSlider" dataElementId="overviewList"/>
            </ThreePartBitmap>
        </GuiElement>

        <GuiElement profile="rlTabContainer" id="newspaperPanel" visible="false">
            <Text profile="rlSectionTitle" id="newspaperTitle" position="0px 0px" text="$l10n_rl_newspaper_title"/>
