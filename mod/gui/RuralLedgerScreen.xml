<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <Bitmap profile="fs25_fullScreenBackground" id="background"/>

    <GuiElement profile="fs25_menuContainer" id="screenContainer">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="fs25_menuHeaderIcon"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" id="categoryHeaderText" text="$l10n_rl_ui_title"/>
        </GuiElement>

        <BoxLayout profile="rlTabBox" id="tabBox">
            <Button profile="rlTabButton" id="overviewTab" text="$l10n_rl_tab_overview" onClick="onClickOverview">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="rlTabButton" id="farmersTab" text="$l10n_rl_tab_farmers" onClick="onClickFarmers">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="rlTabButton" id="detailTab" text="$l10n_rl_tab_farm_detail" onClick="onClickDetail">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="rlTabButton" id="debugTab" text="$l10n_rl_tab_settings_debug" onClick="onClickDebug">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
        </BoxLayout>
        <ThreePartBitmap profile="fs25_lineSeparatorTopHighlighted" position="0px -57px"/>

        <GuiElement profile="rlTabContainer" id="overviewPanel">
            <Text profile="rlSectionTitle" id="overviewTitle" position="0px 0px"/>
            <Text profile="rlSubtleText" id="overviewSubtitle" position="0px -36px"/>
            <Text profile="rlPanelHeading" position="0px -82px" text="$l10n_rl_overview_recent_notes"/>
            <SmoothList profile="rlOverviewList" id="overviewList">
                <ListItem profile="rlInfoListItem">
                    <Text profile="rlInfoListLabel" name="label"/>
                    <Text profile="rlInfoListValue" name="value"/>
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="rlOverviewSliderBox">
                <Slider profile="fs25_listSlider" dataElementId="overviewList"/>
            </ThreePartBitmap>
        </GuiElement>

        <GuiElement profile="rlTabContainer" id="farmersPanel" visible="false">
            <Text profile="rlSectionTitle" position="0px 0px" text="$l10n_rl_farmers_title"/>
            <Text profile="rlSubtleText" position="0px -36px" text="$l10n_rl_farmers_subtitle"/>

            <GuiElement profile="fs25_statisticsHeaderBox" position="0px -82px">
                <Button profile="rlHeaderCell" id="farmHeaderFarm" position="20px 0px" size="260px 32px" text="$l10n_rl_col_farm" handleFocus="false"/>
                <Button profile="rlHeaderCell" id="farmHeaderType" position="290px 0px" size="185px 32px" text="$l10n_rl_col_type" handleFocus="false"/>
                <Button profile="rlHeaderCellCenter" id="farmHeaderFields" position="485px 0px" size="80px 32px" text="$l10n_rl_col_fields" handleFocus="false"/>
                <Button profile="rlHeaderCellCenter" id="farmHeaderStress" position="575px 0px" size="150px 32px" text="$l10n_rl_col_stress" handleFocus="false"/>
                <Button profile="rlHeaderCell" id="farmHeaderPressure" position="735px 0px" size="320px 32px" text="$l10n_rl_col_main_pressure" handleFocus="false"/>
                <Button profile="rlHeaderCell" id="farmHeaderRelation" position="1065px 0px" size="200px 32px" text="$l10n_rl_col_source" handleFocus="false"/>

                <Button profile="rlHeaderCell" id="farmHeaderFarmCompact" position="20px 0px" size="360px 32px" text="$l10n_rl_col_farm" handleFocus="false" visible="false"/>
                <Button profile="rlHeaderCellCenter" id="farmHeaderFieldsCompact" position="390px 0px" size="80px 32px" text="$l10n_rl_col_fields" handleFocus="false" visible="false"/>
                <Button profile="rlHeaderCellCenter" id="farmHeaderStressCompact" position="480px 0px" size="150px 32px" text="$l10n_rl_col_stress" handleFocus="false" visible="false"/>
                <Button profile="rlHeaderCell" id="farmHeaderPressureCompact" position="640px 0px" size="470px 32px" text="$l10n_rl_col_main_pressure" handleFocus="false" visible="false"/>
                <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px -2dp"/>
            </GuiElement>

            <SmoothList profile="rlFarmList" id="farmTable">
                <ListItem profile="rlFarmListItem">
                    <Text profile="rlRowCell" position="20px 0px" size="260px 32px" name="farmName"/>
                    <Text profile="rlRowCell" position="290px 0px" size="185px 32px" name="farmType"/>
                    <Text profile="rlRowCellCenter" position="485px 0px" size="80px 32px" name="farmFields"/>
                    <Text profile="rlRowCellCenter" position="575px 0px" size="150px 32px" name="farmStress"/>
                    <Text profile="rlRowCell" position="735px 0px" size="320px 32px" name="farmPressure"/>
                    <Text profile="rlRowCell" position="1065px 0px" size="200px 32px" name="farmRelation"/>

                    <Text profile="rlRowCell" position="20px 0px" size="360px 32px" name="farmNameCompact" visible="false"/>
                    <Text profile="rlRowCellCenter" position="390px 0px" size="80px 32px" name="farmFieldsCompact" visible="false"/>
                    <Text profile="rlRowCellCenter" position="480px 0px" size="150px 32px" name="farmStressCompact" visible="false"/>
                    <Text profile="rlRowCell" position="640px 0px" size="470px 32px" name="farmPressureCompact" visible="false"/>
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="rlFarmSliderBox">
                <Slider profile="fs25_listSlider" dataElementId="farmTable"/>
            </ThreePartBitmap>
        </GuiElement>

        <GuiElement profile="rlTabContainer" id="detailPanel" visible="false">
            <Text profile="rlSectionTitle" id="detailTitle" position="0px 0px"/>
            <Text profile="rlSubtleText" id="detailSubtitle" position="0px -36px"/>
            <Text profile="rlHeadlineText" id="detailHeadline" position="0px -82px"/>
            <Text profile="rlBodyTextWide" id="detailCause" position="0px -124px"/>
            <Text profile="rlBodyTextWide" id="detailMeaning" position="0px -164px"/>
            <Text profile="rlPanelHeading" position="0px -220px" text="$l10n_rl_detail_public_heading"/>
            <SmoothList profile="rlDetailList" id="detailList">
                <ListItem profile="rlTextListItem">
                    <Text profile="rlTextListLine" name="line"/>
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="rlDetailSliderBox">
                <Slider profile="fs25_listSlider" dataElementId="detailList"/>
            </ThreePartBitmap>
        </GuiElement>

        <GuiElement profile="rlTabContainer" id="debugPanel" visible="false">
            <Text profile="rlSectionTitle" id="debugTitle" position="0px 0px"/>
            <Text profile="rlSubtleText" id="debugModeText" position="0px -36px"/>
            <Button profile="rlSmallButton" position="0px -84px" text="$l10n_rl_button_toggle_debug" onClick="onClickToggleDebug"/>
            <Button profile="rlSmallButton" position="335px -84px" text="$l10n_rl_button_refresh_display" onClick="onClickRefresh"/>
            <Text profile="rlPanelHeading" position="0px -150px" text="$l10n_rl_debug_diagnostics"/>
            <SmoothList profile="rlDebugList" id="debugList">
                <ListItem profile="rlTextListItem">
                    <Text profile="rlTextListLine" name="line"/>
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="rlDebugSliderBox">
                <Slider profile="fs25_listSlider" dataElementId="debugList"/>
            </ThreePartBitmap>
        </GuiElement>
    </GuiElement>

    <BoxLayout profile="fs25_buttonBox" id="buttonsPanel">
        <Button profile="buttonExtra1" text="$l10n_rl_button_refresh" onClick="onClickRefresh" id="menuButton[1]">
            <Bitmap profile="fs25_buttonBoxSeparator" name="separator"/>
        </Button>
        <Button profile="buttonBack" text="$l10n_rl_button_back" onClick="onClickBack" id="menuButton[2]">
            <Bitmap profile="fs25_buttonBoxSeparator" name="separator"/>
        </Button>
    </BoxLayout>

    <GUIProfiles>
        <Profile name="rlTabBox" extends="fs25_subCategorySelectorTabbedBox">
            <position value="0px -10px"/>
        </Profile>
        <Profile name="rlTabButton" extends="fs25_subCategorySelectorTabbedTab">
            <size value="245px 57px"/>
            <textLayoutMode value="resize"/>
        </Profile>
        <Profile name="rlTabContainer" extends="emptyPanel" with="anchorStretchingYStretchingX pivotTopLeft">
            <position value="0px -90px"/>
            <absoluteSizeOffset value="0px 90px"/>
        </Profile>
        <Profile name="rlSectionTitle" extends="fs25_textDefault" with="anchorTopLeft">
            <size value="900px 40px"/>
            <textSize value="28px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textLayoutMode value="resize"/>
        </Profile>
        <Profile name="rlSubtleText" extends="fs25_textDefault" with="anchorTopLeft">
            <size value="1250px 28px"/>
            <textSize value="16px"/>
            <textColor value="0.65 0.68 0.72 1"/>
            <textLayoutMode value="scrolling"/>
        </Profile>
        <Profile name="rlHeadlineText" extends="fs25_textDefault" with="anchorTopLeft">
            <size value="1250px 32px"/>
            <textSize value="22px"/>
            <textBold value="true"/>
            <textColor value="0.88 0.95 1 1"/>
            <textLayoutMode value="scrolling"/>
        </Profile>
        <Profile name="rlPanelHeading" extends="fs25_textDefault" with="anchorTopLeft">
            <size value="700px 28px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="0.9 0.9 0.9 1"/>
        </Profile>
        <Profile name="rlBodyTextWide" extends="fs25_textDefault" with="anchorTopLeft">
            <size value="1250px 28px"/>
            <textSize value="16px"/>
            <textColor value="0.86 0.88 0.9 1"/>
            <textLayoutMode value="scrolling"/>
        </Profile>
        <Profile name="rlHeaderCell" extends="baseReference">
            <imageColor value="0 0 0 0"/>
            <textFocusedColor value="$preset_fs25_colorMainHighlight"/>
            <textHighlightedColor value="$preset_fs25_colorMainHighlight"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textLayoutMode value="resize"/>
        </Profile>
        <Profile name="rlHeaderCellCenter" extends="rlHeaderCell">
            <textAlignment value="center"/>
        </Profile>
        <Profile name="rlOverviewList" extends="emptyPanel" with="anchorStretchingYStretchingX pivotTopLeft">
            <position value="0px -122px"/>
            <absoluteSizeOffset value="0px 180px"/>
        </Profile>
        <Profile name="rlOverviewSliderBox" extends="fs25_listSliderBox" with="anchorTopStretchingX pivotTopRight">
            <position value="28px -122px"/>
            <absoluteSizeOffset value="0px 180px"/>
        </Profile>
        <Profile name="rlFarmList" extends="emptyPanel" with="anchorStretchingYStretchingX pivotTopLeft">
            <position value="0px -124px"/>
            <absoluteSizeOffset value="0px 154px"/>
        </Profile>
        <Profile name="rlFarmSliderBox" extends="fs25_listSliderBox" with="anchorTopStretchingX pivotTopRight">
            <position value="28px -124px"/>
            <absoluteSizeOffset value="0px 154px"/>
        </Profile>
        <Profile name="rlDetailList" extends="emptyPanel" with="anchorStretchingYStretchingX pivotTopLeft">
            <position value="0px -260px"/>
            <absoluteSizeOffset value="0px 285px"/>
        </Profile>
        <Profile name="rlDetailSliderBox" extends="fs25_listSliderBox" with="anchorTopStretchingX pivotTopRight">
            <position value="28px -260px"/>
            <absoluteSizeOffset value="0px 285px"/>
        </Profile>
        <Profile name="rlDebugList" extends="emptyPanel" with="anchorStretchingYStretchingX pivotTopLeft">
            <position value="0px -190px"/>
            <absoluteSizeOffset value="0px 215px"/>
        </Profile>
        <Profile name="rlDebugSliderBox" extends="fs25_listSliderBox" with="anchorTopStretchingX pivotTopRight">
            <position value="28px -190px"/>
            <absoluteSizeOffset value="0px 215px"/>
        </Profile>
        <Profile name="rlInfoListItem" extends="baseReference" with="anchorTopStretchingX alternating">
            <height value="44px"/>
            <imageColor value="$preset_fs25_colorGrey"/>
            <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
            <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
        </Profile>
        <Profile name="rlInfoListLabel" extends="baseReference" with="anchorStretchingYLeft">
            <position value="16px 0px"/>
            <size value="390px 44px"/>
            <textSize value="15px"/>
            <textBold value="true"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textLayoutMode value="scrolling"/>
        </Profile>
        <Profile name="rlInfoListValue" extends="baseReference" with="anchorStretchingYStretchingX">
            <position value="430px 0px"/>
            <absoluteSizeOffset value="450px 0px"/>
            <textSize value="15px"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textLayoutMode value="scrolling"/>
        </Profile>
        <Profile name="rlFarmListItem" extends="baseReference" with="anchorTopStretchingX alternating">
            <height value="34px"/>
            <imageColor value="$preset_fs25_colorGrey"/>
            <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
            <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
        </Profile>
        <Profile name="rlRowCell" extends="baseReference" with="anchorStretchingYLeft">
            <textSize value="13px"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="left"/>
            <textLayoutMode value="scrolling"/>
        </Profile>
        <Profile name="rlRowCellCenter" extends="rlRowCell">
            <textAlignment value="center"/>
        </Profile>
        <Profile name="rlTextListItem" extends="baseReference" with="anchorTopStretchingX alternating">
            <height value="34px"/>
            <imageColor value="$preset_fs25_colorGrey"/>
            <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
            <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
        </Profile>
        <Profile name="rlTextListLine" extends="baseReference" with="anchorStretchingYStretchingX">
            <position value="16px 0px"/>
            <absoluteSizeOffset value="32px 0px"/>
            <textSize value="15px"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textLayoutMode value="scrolling"/>
        </Profile>
        <Profile name="rlSmallButton" extends="buttonOK" with="anchorTopLeft">
            <size value="310px 45px"/>
            <textSize value="14px"/>
            <textLayoutMode value="resize"/>
        </Profile>
    </GUIProfiles>
</GUI>
