    <BoxLayout profile="fs25_buttonBox" id="buttonsPanel">
        <Button profile="rlFooterButton" text="$l10n_rl_button_read_paper" onClick="onClickReadNewspaper" id="readNewspaperFooterButton" disabled="true">
