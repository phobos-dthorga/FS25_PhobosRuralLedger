            </GuiElement>

            <SmoothList profile="rlNewspaperArchiveList" id="newspaperTable">
                <ListItem profile="rlFarmListItem">
                    <Text profile="rlRowCell" position="20px 0px" size="230px 32px" name="edition"/>
                    <Text profile="rlRowCell" position="260px 0px" size="470px 32px" name="headline"/>
