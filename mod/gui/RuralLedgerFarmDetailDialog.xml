<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="rlFarmDetailDialog" id="dialogElement">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">
            <Text profile="dialogTitle" id="detailTitle" position="0px -30px"/>
            <Text profile="rlDialogSubtitle" id="detailSubtitle" position="0px -78px"/>
            <Text profile="rlDialogHeadline" id="detailHeadline" position="0px -116px"/>
            <Text profile="rlDialogBody" id="detailCause" position="0px -156px"/>
            <Text profile="rlDialogBody" id="detailMeaning" position="0px -190px"/>

            <GuiElement profile="fs25_statisticsHeaderBox" position="0px -238px">
                <Text profile="rlHeaderCell" position="16px 0px" size="810px 32px" text="$l10n_rl_detail_public_heading"/>
                <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px -2dp"/>
            </GuiElement>

            <SmoothList profile="rlFarmDetailDialogList" id="detailList" focusInit="onOpen">
                <ListItem profile="rlTextListItem">
                    <Text profile="rlTextListLine" name="line"/>
                </ListItem>
            </SmoothList>
            <ThreePartBitmap profile="rlFarmDetailDialogSliderBox">
                <Slider profile="fs25_listSlider" dataElementId="detailList"/>
            </ThreePartBitmap>
        </GuiElement>

        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonBack" text="$l10n_rl_button_back" onClick="onClickBack"/>
        </BoxLayout>
    </GuiElement>
</GUI>
